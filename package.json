{
  "name": "cc-studio",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test && vp run -r build",
    "dev": "vp run schema#build && vp run -r --parallel dev",
    "build": "vp run web#build",
    "test": "vp test",
    "check": "vp check",
    "prepare": "vp config"
  },
  "devDependencies": {
    "vite-plus": "0.2.1"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.6"
}
